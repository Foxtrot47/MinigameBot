# Telegram API credentials — get from https://my.telegram.org/apps
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Your phone number in international format
PHONE=+15551234567

# The channel to monitor. Use the numeric ID (e.g., -1001234567890)
# or the public username without @ (e.g., somechannel)
TARGET_CHANNEL=-1001234567890

# The bot whose messages we respond to. Use @username or numeric user ID.
TARGET_BOT=@minigame_bot

# Telethon session name (the .session file will be named this)
SESSION_NAME=mingame_session

# Gemini API key — get a free key at https://aistudio.google.com/app/apikey
# Free tier: 1500 requests/day, 15 requests/min
GEMINI_API_KEY=your_gemini_api_key_here
